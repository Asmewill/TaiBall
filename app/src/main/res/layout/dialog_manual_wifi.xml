<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- Top colored bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="#1976D2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Icon -->
        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:src="@android:drawable/stat_sys_wifi_signal_0"
            android:tint="#E53935" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/dialog_title"
            android:textColor="#1A1A2E"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Message -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/dialog_message"
            android:textColor="#757575"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Go to wifi settings button -->
        <Button
            android:id="@+id/btnGoToSettings"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_connect_background"
            android:text="@string/btn_go_to_wifi"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"
            android:layout_marginBottom="10dp" />

        <!-- Cancel button -->
        <Button
            android:id="@+id/btnCancelDialog"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_cancel_background"
            android:text="@string/btn_cancel"
            android:textColor="#1976D2"
            android:textSize="15sp"
            android:stateListAnimator="@null" />

    </LinearLayout>
</LinearLayout>
