<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:padding="0dp"
    android:clipToOutline="true">

    <!-- Warning header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/dialog_header_bg"
        android:paddingTop="28dp"
        android:paddingBottom="20dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <TextView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:text="⚠️"
            android:textSize="36sp"
            android:background="@drawable/circle_orange"
            android:padding="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="无法自动连接WiFi"
            android:textColor="#E65100"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未能找到该WiFi或密码错误，请手动前往系统WiFi设置页面进行连接。"
            android:textColor="#555555"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Steps hint -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/hint_bg"
            android:padding="14dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="操作步骤："
                android:textColor="#1976D2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="① 点击下方按钮进入系统WiFi设置"
                android:textColor="#444444"
                android:textSize="13sp"
                android:layout_marginBottom="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="② 在列表中找到目标WiFi名称"
                android:textColor="#444444"
                android:textSize="13sp"
                android:layout_marginBottom="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="③ 输入密码并手动连接"
                android:textColor="#444444"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:id="@+id/btnManualConnect"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_connect_bg"
            android:text="立即连接设备Wi-Fi"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnCancelDialog"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_cancel_bg"
            android:text="稍后再说"
            android:textColor="#666666"
            android:textSize="16sp" />

    </LinearLayout>

</LinearLayout>
