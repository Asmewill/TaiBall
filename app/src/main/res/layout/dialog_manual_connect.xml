<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:padding="24dp">

    <!-- WiFi Icon -->
    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_wifi_large"
        android:alpha="0.5"
        android:layout_marginBottom="16dp"
        android:contentDescription="WiFi图标" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="无法连接 WiFi"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#D32F2F"
        android:layout_marginBottom="12dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/tv_dialog_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="未找到该WiFi网络或密码不正确，请手动连接设备WiFi。"
        android:textSize="14sp"
        android:textColor="#546E7A"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="24dp" />

    <!-- Connect Now Button -->
    <Button
        android:id="@+id/btn_manual_connect"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="立即连接设备Wi-Fi"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/bg_button_connect"
        android:stateListAnimator="@null" />

    <!-- Cancel Button -->
    <Button
        android:id="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="10dp"
        android:text="取 消"
        android:textSize="15sp"
        android:textColor="#2196F3"
        android:background="@android:color/transparent"
        android:stateListAnimator="@null" />

</LinearLayout>
